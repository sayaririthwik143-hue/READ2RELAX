{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and screen time data",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "name": { "type": "string", "description": "Full name" },
        "email": { "type": "string", "description": "Email address" },
        "profile_photo": { "type": "string", "description": "URL to profile photo" },
        "selected_apps": { "type": "string", "description": "JSON string of selected app IDs" },
        "screen_time_limit": { "type": "number", "description": "Daily limit in minutes" },
        "exercise_minutes_earned": { "type": "number", "description": "Total minutes earned through exercise" },
        "daily_usage": { "type": "number", "description": "Minutes used today" },
        "focus_score": { "type": "number", "description": "Focus score out of 100" },
        "gender": { "type": "string", "description": "User gender (man/woman)" },
        "last_reset": { "type": "string", "description": "ISO date of last usage reset" }
      },
      "required": ["uid", "name", "email"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User documents indexed by their Auth UID"
    }
  }
}
